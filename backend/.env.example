DATABASE_URL=postgresql://pixelbucks:pixelbucks@localhost:5444/pixelbucks
RABBITMQ_URL=amqp://guest:guest@localhost:5777
REDIS_URL=redis://localhost:6777
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
PANDASCORE_TOKEN=your-pandascore-token-here
PANDASCORE_BASE_URL=https://api.pandascore.co
PANDASCORE_TIERS=s,a

# BullMQ job intervals (milliseconds)
# Sync tier S/A tournaments from PandaScore
SYNC_TOURNAMENTS_INTERVAL_MS=1800000
# Sync upcoming matches filtered by synced tournaments
SYNC_MATCHES_INTERVAL_MS=900000
# Detect UPCOMING → LIVE status transitions
DETECT_LIVE_INTERVAL_MS=120000
# Check finished/cancelled match results, write to outbox
CHECK_RESULTS_INTERVAL_MS=300000

THROTTLE_TTL=60000
THROTTLE_LIMIT=60
PORT=3000
FRONTEND_URL=http://localhost:5173
